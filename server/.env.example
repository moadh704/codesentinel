# CodeSentinel Server Environment
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=codesentinel
DB_PORT=3306

# JWT Authentication
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# AI Provider API Keys (configure at least one)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_API_KEY=AIzaSy-your-google-ai-key-here

# CORS - Frontend origin (comma separated for multiple)
FRONTEND_URL=http://localhost:5173

# Optional: Rate limit overrides (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
